{
  "id": "sce-us",
  "name": "Southern California Edison",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "schemaVersion": "uw-plugin-v1",
  "coreVersion": ">=0.1.0 <1.0.0",
  "country": "US",
  "serviceTypes": ["electricity"],
  "homepage": "https://www.sce.com",
  "entrypoint": "./src/index.ts",
  "capabilities": ["auth.login", "accounts.list", "bills.list", "bills.download", "bills.normalize"],
  "auth": {
    "type": "username-password",
    "secretRefs": ["username", "password"]
  },
  "permissions": {
    "network": ["sce.com", "*.sce.com"],
    "artifacts": ["html", "pdf", "screenshot", "json", "text"],
    "filesystem": "artifacts-only",
    "brightData": "supported"
  },
  "quality": {
    "status": "draft",
    "verification": "fixture-only",
    "lastVerified": null,
    "limitations": [
      "Public repo ships the parser with synthetic fixtures only",
      "Live retrieval requires account credentials + the Bright Data Scraping Browser (not in the public repo)",
      "MFA challenges route to human review"
    ]
  },
  "tests": {
    "fixtures": "./fixtures",
    "healthcheck": "npm run test:plugin"
  },
  "support": {
    "maintainer": "Utility Watch Maintainers",
    "url": "https://github.com/kapitecsoluciones/utility-watch/issues"
  }
}
