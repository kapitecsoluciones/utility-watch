{
  "id": "example-provider",
  "name": "Example Utility Provider",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "schemaVersion": "uw-plugin-v1",
  "coreVersion": ">=0.1.0 <1.0.0",
  "country": "US",
  "serviceTypes": ["electricity"],
  "homepage": "https://example.com",
  "entrypoint": "./dist/index.js",
  "capabilities": [
    "auth.login",
    "accounts.list",
    "bills.list",
    "bills.download",
    "bills.normalize"
  ],
  "auth": {
    "type": "username-password",
    "secretRefs": ["username", "password"]
  },
  "permissions": {
    "network": ["example.com", "*.example.com"],
    "artifacts": ["html", "pdf", "screenshot", "json"],
    "filesystem": "artifacts-only",
    "brightData": "unsupported"
  },
  "quality": {
    "status": "draft",
    "verification": "fixture-only",
    "lastVerified": null,
    "limitations": [
      "Synthetic example only",
      "Not connected to a live provider portal"
    ]
  },
  "tests": {
    "fixtures": "./fixtures",
    "healthcheck": "npm run test:plugin"
  },
  "support": {
    "maintainer": "Kapitec",
    "url": "https://github.com/kapitecsoluciones/utility-watch/issues"
  }
}
