# Core runtime configuration. Copy to .env and adjust.
# This file is the ONLY env example allowed in the public repo. Never commit a real .env.

# Database (matches docker-compose.yml defaults)
DATABASE_URL=mysql://utility_watch:utility_watch@localhost:3306/utility_watch

# Docker Compose MySQL bootstrap (consumed by docker-compose.yml only)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=utility_watch
MYSQL_USER=utility_watch
MYSQL_PASSWORD=utility_watch
MYSQL_PORT=3306

# Local storage
ARTIFACTS_DIR=./data/artifacts
EXPORTS_DIR=./data/exports

# App
APP_BASE_URL=http://localhost:3000
INSTALL_TYPE=local-demo
LOG_LEVEL=info

# Review policy
REVIEW_CONFIDENCE_THRESHOLD=0.85

# Bright Data Scraping Browser adapter — DISABLED by default, opt-in only.
BRIGHTDATA_ENABLED=false
BRIGHTDATA_API_KEY=
BRIGHTDATA_BROWSER_URL=
